// Concord data model — SQLite (local file, zero external services).
// SQLite keeps self-hosting trivial: one file, no Postgres/Redis to run.
// Enum-like fields are plain strings (SQLite has no native enums).
//   ChannelType:    TEXT | VOICE | CATEGORY | ANNOUNCEMENT | FORUM | STAGE
//   PresenceStatus: ONLINE | IDLE | DND | OFFLINE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String
  discriminator String   @default("0000") // username#0000 (legacy-style tag)
  email         String   @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  bannerUrl     String?
  accentColor   String?
  bio           String?
  status        String   @default("OFFLINE")
  customStatus  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedGuilds   Guild[]         @relation("GuildOwner")
  memberships   GuildMember[]
  messages      Message[]
  refreshTokens RefreshToken[]

  @@unique([username, discriminator])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
}

model Guild {
  id          String   @id @default(cuid())
  name        String
  iconUrl     String?
  bannerUrl   String?
  vanityUrl   String?  @unique
  description String?
  ownerId     String
  owner       User     @relation("GuildOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channels    Channel[]
  members     GuildMember[]
  roles       Role[]

  @@index([ownerId])
}

model Role {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String
  color       String   @default("#99aab5")
  // Permission bitfield stored as string (BigInt range, 53+ flags).
  permissions String   @default("0")
  position    Int      @default(0)
  hoist       Boolean  @default(false)
  mentionable Boolean  @default(false)
  isDefault   Boolean  @default(false) // the @everyone role
  createdAt   DateTime @default(now())

  members     GuildMember[]

  @@index([guildId])
}

model GuildMember {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname  String?
  joinedAt  DateTime @default(now())
  roles     Role[]

  @@unique([guildId, userId])
  @@index([userId])
}

model Channel {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("TEXT")
  topic     String?
  position  Int      @default(0)
  parentId  String? // category
  parent    Channel? @relation("ChannelParent", fields: [parentId], references: [id], onDelete: SetNull)
  children  Channel[] @relation("ChannelParent")
  // voice config (no caps): bitrate up to lossless, userLimit 0 = unlimited
  bitrate   Int      @default(64000)
  userLimit Int      @default(0)
  slowmode  Int      @default(0)
  createdAt DateTime @default(now())

  messages  Message[]

  @@index([guildId])
  @@index([parentId])
}

model Message {
  id        String    @id @default(cuid())
  channelId String
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  content   String    // up to MAX_MESSAGE_LENGTH (default 100k)
  replyToId String?
  replyTo   Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReply")
  pinned    Boolean   @default(false)
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  attachments Attachment[]

  @@index([channelId, createdAt])
  @@index([authorId])
}

model Attachment {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  size      Int // bytes (no cap)
  mimeType  String
  width     Int?
  height    Int?

  @@index([messageId])
}
